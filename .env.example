# Copy to `.env` in the project root and fill in values. `.env` is gitignored.
#
# Duke OIT hosts an OpenAI-compatible LiteLLM proxy:
#   Docs / Swagger: https://litellm.oit.duke.edu/
# Use the API key issued in the LiteLLM Admin Panel (or your course key).
# List models your key can call: GET https://litellm.oit.duke.edu/v1/models

# Required — same header the OpenAI Python client sends: Authorization: Bearer <key>
OPENAI_API_KEY=

# Must match a model id from /v1/models on the proxy (names differ from public OpenAI).
# Mid-tier default in config.py balances quality vs ~$1/day experimentation.
OPENAI_MODEL=gpt-5.4-mini

# Required for Duke LiteLLM — OpenAI SDK `base_url` (include `/v1`, no trailing slash).
OPENAI_BASE_URL=https://litellm.oit.duke.edu/v1

# If you ever call api.openai.com directly instead:
# OPENAI_BASE_URL=https://api.openai.com/v1
