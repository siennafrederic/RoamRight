# Copy this file to `.env` and fill values locally. `.env` is gitignored.

# ---- Primary path: local OSS model via Ollama (recommended, zero API cost) ----
LLM_PROVIDER=ollama
LLM_MODEL=mistral:7b-instruct
LLM_BASE_URL=http://localhost:11434/v1
# Optional placeholder; Ollama accepts dummy key for OpenAI-compatible clients.
LLM_API_KEY=ollama

# ---- Optional path: remote OpenAI-compatible proxy (LiteLLM, etc.) ----
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=gpt-5.4-mini
# LLM_BASE_URL=https://litellm.oit.duke.edu/v1
# LLM_API_KEY=

# Backward compatibility if older modules still reference OPENAI_* names.
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_BASE_URL=

# Optional: point retrieval to a specific activities dataset file.
# Example:
# ROAMRIGHT_ACTIVITIES_PATH=/Users/you/Downloads/roamright_spain_madrid_barcelona_activities_v1.json
# ROAMRIGHT_ACTIVITIES_PATH=data/activities.json
ROAMRIGHT_ACTIVITIES_PATH=data/roamright_spain_madrid_barcelona_activities_v1.json

# ---- Optional live event ingestion ----
USE_LIVE_EVENTS=false
TICKETMASTER_API_KEY=
